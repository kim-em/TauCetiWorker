# ============================================================================
# run() — subprocess helpers. close_fds=True (Python default) means children never
# inherit the round.lock fd, retiring round.sh's hand-managed `9>&-` fd-leak fix.
# ============================================================================

class GitHubError(Exception):
    """A `gh` call failed (distinct from 'ran fine, returned no rows')."""


def run(argv: list[str], *, cwd: Optional[Path] = None, env: Optional[dict] = None,
        capture: bool = True, check: bool = False, input_text: Optional[str] = None) -> subprocess.CompletedProcess:
    return subprocess.run(
        argv, cwd=str(cwd) if cwd else None, env=env, text=True,
        capture_output=capture, input=input_text, check=check,
    )


# ============================================================================
# GitHub — every gh wrapper. JSON via `gh ... --json` + stdlib json (no jq).
# ============================================================================

class GitHub:
    def __init__(self, repo: str = TAUCETI):
        self.repo = repo

    def _gh(self, args: list[str]) -> subprocess.CompletedProcess:
        return run(["gh", *args])

    def pr_list(self, fields: list[str], *, author: Optional[str] = None, state: str = "open") -> list[dict]:
        args = ["pr", "list", "--repo", self.repo, "--state", state, "--limit", "200",
                "--json", ",".join(fields)]
        if author:
            args += ["--author", author]
        p = self._gh(args)
        if p.returncode != 0:
            raise GitHubError(f"gh pr list failed: {p.stderr.strip()}")
        return json.loads(p.stdout or "[]")

    def pr_view(self, pr: int, fields: list[str]) -> Optional[dict]:
        p = self._gh(["pr", "view", str(pr), "--repo", self.repo, "--json", ",".join(fields)])
        if p.returncode != 0:
            return None
        return json.loads(p.stdout or "{}")

    def issue_comments(self, pr: int) -> Optional[list[dict]]:
        """All issue comments for a PR (paginated). None on fetch failure (distinct from empty)."""
        p = self._gh(["api", "--paginate", f"/repos/{self.repo}/issues/{pr}/comments?per_page=100"])
        if p.returncode != 0:
            return None
        try:
            return json.loads(p.stdout or "[]")
        except json.JSONDecodeError:
            return None

    def review_comments(self, pr: int) -> Optional[list[dict]]:
        """All review (inline / thread) comments for a PR — distinct from issue_comments. A contested
        fix replies on a review thread, so the progress guard must count these too. None on failure."""
        p = self._gh(["api", "--paginate", f"/repos/{self.repo}/pulls/{pr}/comments?per_page=100"])
        if p.returncode != 0:
            return None
        try:
            return json.loads(p.stdout or "[]")
        except json.JSONDecodeError:
            return None

    def api_jq(self, path: str, jq: str) -> Optional[str]:
        p = self._gh(["api", path, "--jq", jq])
        if p.returncode != 0:
            return None
        return p.stdout.strip()


# ============================================================================
# Counters — state/<wid>/... single-integer files (round.sh `counter`).
# ============================================================================

class Counters:
    def __init__(self, cfg: Config):
        self.state = cfg.state

    def read(self, name: str) -> int:
        try:
            txt = (self.state / name).read_text().strip()
        except OSError:
            return 0
        return int(txt) if txt.isdigit() else 0

    def write(self, name: str, value: int) -> None:
        self.state.mkdir(parents=True, exist_ok=True)
        (self.state / name).write_text(str(value))

    def incr(self, name: str) -> int:
        v = self.read(name) + 1
        self.write(name, v)
        return v


# ============================================================================
# Quota — self-contained pacer. Direct API reads of the same credential files the
# official CLIs maintain (no ~/.claude skill, no gist, no curve files). Paces
# `used% ≤ elapsed%` on BOTH the session and weekly windows of each provider — the
# shippable form of the linear curve. Auto-selection prefers codex (spare Opus).
# Treats the reverse-engineered endpoints as UNSTABLE adapters: schema-tolerant,
# clock-normalized, explicit unknown/exhausted states, raw responses cached.
# ============================================================================

import base64
import urllib.error
import urllib.request

