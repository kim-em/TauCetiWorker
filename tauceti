def _sample(cands: list[Candidate], n: int = 3) -> str:
    nums = [f"#{c.pr}" for c in cands]
    head = " ".join(nums[:n])
    return head + (f" +{len(nums) - n}" if len(nums) > n else "")


def quota_line(snap: dict) -> str:
    """One-line quota summary from a {provider: Provider} snapshot."""
    parts = []
    for name in ("codex", "claude"):
        prov = snap.get(name)
        if prov is None:
            continue
        if prov.error:
            parts.append(f"{name} [yellow]?[/] ({prov.error})")
        elif prov.available:
            parts.append(f"{name} [green]✓[/] {prov.model}")
        else:
            why = prov.model or "over-pace/exhausted"
            parts.append(f"{name} [red]✗[/] ({why})")
    return "   ".join(parts) if parts else "quota: (not checked)"


def render_survey(sv: Survey, console, quota_snap: Optional[dict] = None) -> None:
    from rich.table import Table
    from rich.panel import Panel

    if sv.github_failed:
        console.print(Panel("[bold red]GitHub fetch failed[/] — survey unavailable.\n"
                            + "\n".join(sv.errors), title="tauceti"))
        return

    header = (f"[bold]{TAUCETI}[/]   worker: {sv.worker_id}   "
              f"open: {sv.n_open_nondraft} non-draft, {sv.n_reviewable} build-green")
    if quota_snap is not None:
        header += "\nquota: " + quota_line(quota_snap)
    console.print(Panel(header, title="tauceti"))

    t = Table(show_header=True, header_style="bold")
    t.add_column("KIND"); t.add_column("READY", justify="right"); t.add_column("SAMPLE / NOTE")
    for name in ("rebase", "review", "fix", "fix-ci"):
        wk = sv.kind(name)
        ready = str(wk.count) if wk.count else "—"
        extra = f"  (+{len(wk.suppressed)} past-budget)" if wk.suppressed else ""
        t.add_row(name, ready, (_sample(wk.actionable) or "") + extra)
    # bump
    if sv.bump.due:
        t.add_row("bump", "1", f"mathlib master {sv.bump.master_tip[:12] if sv.bump.master_tip else '?'} ahead of pin")
    else:
        note = "pin current with master" if sv.bump.master_tip and sv.bump.master_tip == sv.bump.our_pin else \
               ("bump PR already open" if sv.bump.bump_pr_open else
                ("over budget" if sv.bump.behind else "unknown"))
        t.add_row("bump", "—", note)
    # roadmap
    if sv.roadmap_backpressure:
        t.add_row("roadmap", "⛔", f"backpressure: {sv.n_mine_open}/{MAX_OPEN_PRS} open  (focus: {sv.roadmap_focus})")
    else:
        t.add_row("roadmap", "∞", f"focus: {sv.roadmap_focus}")
    console.print(t)

    h = Table(show_header=True, header_style="bold dim", title="housekeeping (quota-free, every round)")
    h.add_column("KIND"); h.add_column("READY", justify="right"); h.add_column("SAMPLE / NOTE")
    h.add_row("merge", str(len(sv.mergeable_now)) or "—", _sample(sv.mergeable_now) or "—")
    h.add_row("abandon", str(len(sv.abandon_eligible)) or "—", _sample(sv.abandon_eligible) or "—")
    dups = [pr for group in sv.dup_groups.values() for pr in group[1:]]
    h.add_row("dup-sweep", str(len(dups)) or "—", " ".join(f"#{p}" for p in dups[:3]) or "—")
    console.print(h)

    nxt = sv.next_auto_stage
    console.print(f"\nNext auto round would: [bold]{nxt.upper() if nxt else 'NOTHING (no eligible work)'}[/]")


def cmd_status(args) -> int:
    cfg = Config.resolve(getattr(args, "worker_id", None))
    gh = GitHub()
    rs = ReviewState(cfg, gh)
    counters = Counters(cfg)
    sv = survey(cfg, gh, rs, counters, deep=True)
    _, quota_snap = Quota(cfg).choose(None)

    if getattr(args, "json", False):
        out = {"survey": dataclasses.asdict(sv),
               "quota": {k: dataclasses.asdict(v) for k, v in quota_snap.items()}}
        print(json.dumps(out, indent=2, default=str))
        return 1 if sv.github_failed else 0

    from rich.console import Console
    render_survey(sv, Console(), quota_snap)
    return 1 if sv.github_failed else 0


def cmd_work(args, *, only: list[str], agent: str, one_round: bool) -> int:
    # --isolate-home must set $HOME BEFORE Config.resolve (so cfg.home + credential paths point at the
    # per-worker copy). Children spawned by the loop inherit $HOME and don't re-isolate.
    if getattr(args, "isolate_home", False):
        isolate_home(sanitize_wid(getattr(args, "worker_id", None)
                                  or os.environ.get("TAUCETI_WORKER_ID", "default") or "default"))
    cfg = Config.resolve(getattr(args, "worker_id", None))
    if getattr(args, "loop", False) and not one_round:
        return cmd_loop(args, cfg, only=only, agent=agent)
    dry = getattr(args, "dry_run", False)
    ignore_quota = getattr(args, "ignore_quota", False)
    quota_cmd = getattr(args, "quota_cmd", None)

    with RoundContext(cfg) as ctx:   # one round per worker; cleanup + SIGTERM/SIGINT handling
        # Lifecycle test hooks (no GitHub, no model, no mutation) — exercise lock / fd-leak / timeout.
        hb = os.environ.get("TAUCETI_TEST_HEARTBEAT")
        if hb:
            Claims(cfg, ctx).start_heartbeat("branch/test")
            log(f"[test] heartbeat started; holding {hb}s then exiting")
            time.sleep(int(hb))
            return 0
        hold = os.environ.get("TAUCETI_TEST_HOLD")
        if hold:
            subprocess.Popen(["sleep", hold])   # grandchild; close_fds=True ⇒ must NOT inherit the lock fd
            log(f"[test] spawned 'sleep {hold}' grandchild, round exiting immediately")
            return 0
        slp = os.environ.get("TAUCETI_TEST_SLEEP")
        if slp:
            log(f"[test] holding the lock and sleeping {slp}s")
            time.sleep(int(slp))
            return 0

        # Housekeeping-only (--only merge, no work task): drives no model, so don't resolve/pace one.
        housekeeping_only = bool(only) and not any(t in WORK_TASKS for t in only)
        work_model = "none" if housekeeping_only else resolve_work_model(
            cfg, agent, dry=dry, ignore_quota=ignore_quota, quota_cmd=quota_cmd)
        gh = GitHub()
        w = Worker(cfg, gh, ReviewState(cfg, gh), Counters(cfg), ctx, Claims(cfg, ctx))
        opts = RoundOpts(only=only, agent=agent, work_model=work_model,
                         sandbox_host=getattr(args, "host", False), dry_run=dry,
                         ignore_quota=ignore_quota, quota_cmd=quota_cmd)
        if not dry:
            preflight(cfg, opts)
        return run_round(w, opts)   # NoProgress/Die propagate to main()'s handler


def cmd_loop(args, cfg: Config, *, only: list[str], agent: str) -> int:
    """The driver: pace against quota (codex preferred), run ONE round as a child under a hard timeout,
    then settle (short pause if productive, escalating back-off otherwise). Ctrl-C stops the current
    round and exits. Mirrors loop.sh — including the back-off that stopped ~700 no-op rounds hammering
    a rate-limited GitHub."""
    openrouter = agent in OPENROUTER_MODELS
    housekeeping = bool(only) and not any(t in WORK_TASKS for t in only)
    ignore_quota = getattr(args, "ignore_quota", False)
    host = getattr(args, "host", False)
    quota_cmd = getattr(args, "quota_cmd", None)
    log(f"loop start: worker={cfg.wid} only={','.join(only) or '(all)'} agent={agent}"
        f"{' [housekeeping]' if housekeeping else ''}{' [host]' if host else ''}")
    streak = 0
    try:
        while True:
            # 1) Decide the model and whether to run this cycle.
            if housekeeping:
                model = None                       # no model; run every cycle (loop.sh HOUSEKEEPING_ONLY)
            elif openrouter:
                model = agent                      # pay-per-token; no quota wait
            elif ignore_quota and not quota_cmd:
                if agent == "auto":
                    raise SystemExit("--ignore-quota --loop needs an explicit --agent (codex/claude)")
                model = agent
            else:
                model, snap = choose_model(cfg, agent, quota_cmd)
                if model is None:
                    log(f"quota: {quota_line(snap)} — sleeping {POLL}s")
                    time.sleep(POLL)
                    continue

            # 2) Run ONE round as a child in its own process group, under the hard timeout.
            tail = ["--worker-id", cfg.wid]
            if only:
                tail += ["--only", ",".join(only)]
            if model:
                tail += [f"--agent", model, "--ignore-quota"]   # loop already paced; child must not re-pace
            if host:
                tail.append("--host")
            rc = run_round_subprocess(tail)

            # 3) Settle: productive → short pause; no-progress/timeout/error → escalating back-off.
            if rc == 0:
                streak = 0
                time.sleep(INTERROUND)
            else:
                streak += 1
                nap = min(BACKOFF_BASE * (1 << min(streak, 5)), BACKOFF_MAX)
                tag = "timed out" if rc in (124, 137) else ("no progress" if rc == EX_NOPROGRESS else f"rc={rc}")
                log(f"round {tag}; no-progress streak={streak} — backing off {nap}s")
                time.sleep(nap)
    except KeyboardInterrupt:
        log("loop interrupted — stopping")
        return 130


def isolate_home(wid: str) -> Path:
    """Give this worker its OWN $HOME so its credential refreshes can't race other workers or the
    operator (Codex review / loop.sh --isolate-home). Symlinks the read-only Claude tool/config surface
    from the real home; copies the mutable Claude/Codex auth files in ONCE (thereafter the worker
    refreshes within its own copy). Returns the worker home and sets $HOME. Child rounds inherit it."""
    import shutil
    real = Path(os.environ.get("HOME", os.path.expanduser("~")))
    home = HERE / "state" / wid / "home"
    (home / ".claude").mkdir(parents=True, exist_ok=True)
    (home / ".codex").mkdir(parents=True, exist_ok=True)
    for item in ("skills", "swap-account", "bin", "config.json", "settings.json", "CLAUDE.md"):
        src, dst = real / ".claude" / item, home / ".claude" / item
        if src.exists() and not dst.exists():
            try:
                dst.symlink_to(src)
            except OSError:
                pass
    for f in (".credentials.json", ".gist-id", ".gist-encryption-key"):
        src, dst = real / ".claude" / f, home / ".claude" / f
        if src.exists() and not dst.exists():
            shutil.copy2(src, dst)
    src, dst = real / ".codex" / "auth.json", home / ".codex" / "auth.json"
    if src.exists() and not dst.exists():
        shutil.copy2(src, dst)
    os.environ["HOME"] = str(home)
    log(f"isolated HOME={home} (worker '{wid}')")
    return home


def choose_model(cfg: Config, agent: str, quota_cmd: Optional[str]) -> tuple[Optional[str], dict]:
    """Decide which model to run now. With --quota-cmd / TAUCETI_QUOTA_CMD set, consult that external
    command instead of the built-in pacer (the escape hatch for e.g. a multi-account scheme): run
    `<quota_cmd> <agent>`; its first stdout token is the model to run (codex/claude/deepseek/minimax)
    or empty = none available. Otherwise use the self-contained pacer."""
    if quota_cmd:
        import shlex
        r = subprocess.run(shlex.split(quota_cmd) + [agent], capture_output=True, text=True)
        out = (r.stdout or "").split()
        model = out[0] if (r.returncode == 0 and out) else None
        return (model or None), {"quota-cmd": Provider("quota-cmd", bool(model), model)}
    return Quota(cfg).choose(None if agent == "auto" else agent)


def resolve_work_model(cfg: Config, agent: str, *, dry: bool, ignore_quota: bool,
                       quota_cmd: Optional[str] = None) -> str:
    """Turn the --agent dial into the concrete model to run. 'auto' consults the pacer (or --quota-cmd);
    codex preferred, opus fallback. OpenRouter agents are pay-per-token (no pacing). Dry-run symbolic."""
    if dry:
        return agent
    if agent in OPENROUTER_MODELS:
        return agent
    if ignore_quota and not quota_cmd:
        if agent == "auto":
            raise SystemExit("--ignore-quota needs an explicit --agent (codex/claude); 'auto' can't choose without the pacer")
        return agent
    chosen, _snap = choose_model(cfg, agent, quota_cmd)
    if chosen is None:
        raise NoProgress(f"no model under pace right now (agent={agent}) — nothing to run this round")
    return chosen


KIND_KEYS = {"1": "rebase", "2": "review", "3": "fix", "4": "fix-ci", "5": "bump", "6": "roadmap"}


def launch_cmd(only: Optional[str], model_dial: str, host: bool, loop: bool) -> list[str]:
    """Build the exact `tauceti work` command a TUI action runs/spawns (also shown via 'copy command')."""
    cmd = [str(Path(__file__).resolve()), "work"]
    if loop:
        cmd.append("--loop")
    if only:
        cmd += ["--only", only]
    if model_dial != "auto":
        cmd.append(f"--{model_dial}")
    if host:
        cmd.append("--host")
    return cmd


def cmd_tui(args) -> int:
    """Default view: a dashboard of available work + a launcher. NOT a supervisor — launching a loop
    detaches it (coordination lives in GitHub, not here). Over a pipe / no TTY it prints a snapshot."""
    from rich.console import Console
    console = Console()
    cfg = Config.resolve(None)

    def snapshot() -> "Survey":
        gh = GitHub()
        sv = survey(cfg, gh, ReviewState(cfg, gh), Counters(cfg), deep=True)
        _, q = Quota(cfg).choose(None)
        render_survey(sv, console, q)
        return sv

    if not sys.stdin.isatty():
        snapshot()
        console.print("[dim](not a TTY — snapshot only; use `tauceti status [--json]` in scripts)[/]")
        return 0

    model_dial, host = "auto", False
    while True:
        console.clear()
        sv = snapshot()
        sandbox = "host" if host else "bubble"
        console.print(
            f"\n  [bold]model[/]={model_dial}  [bold]sandbox[/]={sandbox}\n"
            "  [enter] one auto round   [1..6] one round of KIND   [l] loop (auto)   "
            "[L] focused loop of KIND\n  [m] cycle model   [s] toggle sandbox   [r] refresh   "
            "[c] copy command   [q] quit")
        try:
            choice = input("  > ").strip()
        except EOFError:
            return 0
        if choice == "q":
            return 0
        if choice == "r":
            continue
        if choice == "m":
            order = ["auto", "codex", "claude", "deepseek", "minimax"]
            model_dial = order[(order.index(model_dial) + 1) % len(order)]
            continue
        if choice == "s":
            host = not host
            continue
        if choice in ("", "l") or choice in KIND_KEYS or choice == "L":
            loop = choice in ("l", "L")
            only = None
            if choice in KIND_KEYS:
                only = KIND_KEYS[choice]
            elif choice == "L":
                k = input("  loop which KIND? (rebase/review/fix/fix-ci/bump/roadmap) > ").strip()
                if k not in ALLOWED_TASKS:
                    console.print(f"[red]unknown kind '{k}'[/]"); input("  enter…"); continue
                only = k
            cmd = launch_cmd(only, model_dial, host, loop)
            if loop:
                _launch_detached(cfg, cmd, console)
                input("  enter to return…")
            else:
                console.print(f"\n  running: {' '.join(_shq(a) for a in cmd)}\n")
                os.execvp(cmd[0], cmd)   # replace this process; the round owns the tty
        if choice == "c":
            for loop in (False, True):
                console.print("  " + " ".join(_shq(a) for a in launch_cmd(None, model_dial, host, loop)))
            input("  enter…")


def _launch_detached(cfg: Config, cmd: list[str], console) -> None:
    cfg.logdir.mkdir(parents=True, exist_ok=True)
    logf = cfg.logdir / f"loop-{time.strftime('%Y%m%d-%H%M%S')}.log"
    f = open(logf, "ab")
    p = subprocess.Popen(cmd, stdin=subprocess.DEVNULL, stdout=f, stderr=f, start_new_session=True)
    console.print(f"\n  started loop  pid {p.pid}  →  {logf}\n"
                  f"  command: {' '.join(_shq(a) for a in cmd)}\n"
                  f"  stop it: kill {p.pid}\n")


def _have(tool: str) -> bool:
    import shutil
    return shutil.which(tool) is not None


def cmd_doctor(args) -> int:
    """Report which capabilities the environment can do, and suggest --host where bubble is missing."""
    cfg = Config.resolve(getattr(args, "worker_id", None))
    rows: list[tuple[str, bool, str]] = []
    for t in ("gh", "git", "jq", "uvx"):
        rows.append((t, _have(t), "required" if t in ("gh", "git") else
                     ("review engine" if t == "uvx" else "claim.sh needs it")))
    gh_auth = subprocess.run(["gh", "auth", "status"], capture_output=True).returncode == 0
    rows.append(("gh auth", gh_auth, "logged in as kim-em"))
    rows.append(("lake", _have("lake"), "host authoring (--host) builds with it"))
    rows.append(("bubble", _have("bubble"), "default sandbox; without it pass --host"))
    rows.append(("pi", _have("pi"), "for --agent deepseek/minimax"))
    # Quota credentials (read-only).
    rows.append(("codex creds", (cfg.home / ".codex" / "auth.json").exists(), "~/.codex/auth.json"))
    rows.append(("claude creds", (cfg.home / ".claude" / ".credentials.json").exists(),
                 "~/.claude/.credentials.json"))
    bad = 0
    print(f"tauceti doctor — worker '{cfg.wid}'")
    for name, ok, note in rows:
        mark = "ok " if ok else "MISSING"
        if not ok and name in ("gh", "git", "gh auth"):
            bad += 1
        print(f"  [{mark:7}] {name:14} {note}")
    if not _have("bubble"):
        print("  note: bubble missing → every model mode needs --host (the host path still works).")
    return 1 if bad else 0


def preflight(cfg: Config, opts: "RoundOpts") -> None:
    """Fail a round early if its chosen mode can't run, rather than partway through."""
    for t in ("gh", "git"):
        if not _have(t):
            raise Die(f"preflight: missing '{t}' on PATH")
    if want(opts.only, "review") and not _bubble("review", opts) and not _have("uvx"):
        raise Die("preflight: --host review needs 'uvx' on PATH (the tauceti-review engine; "
                  "bubble review runs the engine with the image's python3)")
    needs_bubble = any(_bubble(s, opts) for s in WORK_TASKS if want(opts.only, s))
    needs_host_build = any((not _bubble(s, opts)) for s in WORK_TASKS if want(opts.only, s))
    if needs_bubble and not _have("bubble"):
        raise Die("preflight: bubble is the default for model modes but is not on PATH — pass --host, "
                  "or install kim-em/bubble")
    if needs_host_build and not _have("lake") and not opts.dry_run:
        raise Die("preflight: --host authoring needs an elan/lake toolchain on PATH (or drop --host)")


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Die as e:
        log(str(e))
        sys.exit(1)
    except NoProgress as e:
        log(str(e))
        sys.exit(EX_NOPROGRESS)
    except KeyboardInterrupt:
        sys.exit(130)
